{
  "name": "anki-sprache",
  "version": "1.0.0",
  "private": true,
  "description": "仿 Anki 風格的多語言學習 Web App，採用 FSRS 間隔重複演算法 | Anki-style multi-language learning web app with FSRS spaced repetition",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.20.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:app": "pnpm --filter app dev",
    "dev:server": "pnpm --filter server dev",
    "dev:worker": "pnpm --filter server dev:worker",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter server prisma migrate dev",
    "db:seed": "pnpm --filter server prisma db seed",
    "db:studio": "pnpm --filter server prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  }
}

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

DATABASE_URL=postgresql://anki:anki_dev_password@localhost:5432/anki_sprache?schema=public&connection_limit=10
REDIS_URL=redis://localhost:6379

CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# AES-256-GCM master key, 32 bytes base64
MASTER_KEY=change-me-base64-32-bytes

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Cloudflare R2 (S3-compatible) for TTS audio storage
# Create a bucket + API token at https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=change-me-r2-account-id
R2_ACCESS_KEY_ID=change-me-r2-access-key
R2_SECRET_ACCESS_KEY=change-me-r2-secret
R2_BUCKET=change-me-r2-bucket
# Public URL for the bucket (enable "Public access" or connect a custom domain)
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# Google Cloud Text-to-Speech REST API key
# Create at https://console.cloud.google.com/apis/credentials and restrict to
# the "Cloud Text-to-Speech API".
GOOGLE_TTS_API_KEY=change-me-google-tts-key

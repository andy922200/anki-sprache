{
  "name": "anki-sprache-server",
  "version": "1.0.0",
  "private": true,
  "description": "後端 API 與 BullMQ Worker：提供 FSRS 排程、BYOK LLM 生成與 Google OAuth 認證 | Backend API and BullMQ worker: FSRS scheduling, BYOK LLM generation and Google OAuth authentication",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "dev:worker": "tsx watch --env-file=.env src/worker.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node --env-file=.env dist/index.js",
    "start:worker": "node --env-file=.env dist/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma": "prisma",
    "prisma:generate": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.76.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.34.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ts-fsrs": "^4.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}

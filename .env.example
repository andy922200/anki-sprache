# Root-level example file. Each workspace (app/, server/) has its own .env.
# Keep this in sync with server/.env.example and app/.env.example.

# --- Shared ---
NODE_ENV=development

# --- Server ---
DATABASE_URL=postgresql://anki:anki_dev_password@localhost:5432/anki_sprache?schema=public&connection_limit=10
REDIS_URL=redis://localhost:6379
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# JWT signing. Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# AES-256-GCM master key for BYOK encryption. Must be 32 bytes (base64-encoded).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=change-me-base64-32-bytes

# Google OAuth client ID (Web application type)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Cloudflare R2 (S3-compatible) for TTS audio storage
R2_ACCOUNT_ID=change-me-r2-account-id
R2_ACCESS_KEY_ID=change-me-r2-access-key
R2_SECRET_ACCESS_KEY=change-me-r2-secret
R2_BUCKET=change-me-r2-bucket
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# Google Cloud Text-to-Speech REST API key (restricted to TTS API)
GOOGLE_TTS_API_KEY=change-me-google-tts-key

# --- App (exposed to browser, must be prefixed with VITE_) ---
VITE_API_BASE_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
